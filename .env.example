# ─── QVAC ────────────────────────────────────────────────────────────────────
# Path to the local model file Wally loads for intent parsing.
# Find your downloaded models at ~/.qvac/models/ — pick a Qwen3 4B or larger .gguf file.
# Example: QVAC_MODEL_ID=/Users/you/.qvac/models/6dea07e2f9342ff3_Qwen3-4B-Q4_K_M.gguf
# The model is loaded once at startup; the first message will take a few extra seconds.
QVAC_MODEL_ID=

# ─── WDK Seed (choose one source; WDK_SEED_COMMAND is recommended in production) ─
# WDK_SEED_COMMAND — shell command whose stdout is the 12/24-word BIP-39 seed.
# Example: WDK_SEED_COMMAND=op read op://Personal/WallyWallet/seed
WDK_SEED_COMMAND=

# WDK_SEED_FILE — path to a file containing only the seed phrase.
WDK_SEED_FILE=

# WDK_SEED — the seed phrase directly (development only; never use in production).
WDK_SEED=

# ─── WDK Chains ───────────────────────────────────────────────────────────────
# Comma-separated list of chains to enable in the WDK MCP subprocess.
# Supported by installed packages: ethereum, arbitrum, bitcoin
WDK_CHAINS=ethereum,arbitrum,bitcoin

# ─── WDK RPC Endpoints ────────────────────────────────────────────────────────
# Override default public RPC endpoints. Optional but recommended for production.
WDK_RPC_ETHEREUM=https://rpc.mevblocker.io/fast
WDK_RPC_ARBITRUM=https://arb1.arbitrum.io/rpc

# ─── WDK Indexer ──────────────────────────────────────────────────────────────
# Enables on-chain transaction history queries ("how much did I send last week").
# Get a key from https://wdk.tether.io
WDK_INDEXER_API_KEY=

# ─── Network ──────────────────────────────────────────────────────────────────
# testnet | mainnet
NETWORK_MODE=testnet

# ─── Gasless (ERC-4337 smart account) ─────────────────────────────────────────
# Optional: pay gas in USDT instead of ETH via a bundler/paymaster provider.
# Setup guide: GASLESS.md. Copy wdk.config.example.json to wdk.config.json,
# fill in your provider values, then uncomment both lines.
# WDK_CONFIG=./wdk.config.json
# WALLY_GASLESS_CHAINS=arbitrum

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info

# Secret used to sign session cookies. Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-in-production
